-- =========================
-- ESP PRO (ADVANCED)
-- =========================

local ESPEnabled = false
local ESP_Box = true
local ESP_Name = true
local ESP_Distance = true
local ESP_Line = true

local ESPObjects = {}

local function getRGB()
    local t = tick()
    return Color3.fromRGB(
        math.sin(t)*127+128,
        math.sin(t+2)*127+128,
        math.sin(t+4)*127+128
    )
end

local function CreateESP(plr)
    if plr == player then return end
    if ESPObjects[plr] then return end

    local esp = {}

    -- กรอบ
    local highlight = Instance.new("Highlight")
    highlight.FillTransparency = 1
    highlight.Parent = game.CoreGui

    -- ชื่อ
    local billboard = Instance.new("BillboardGui")
    billboard.Size = UDim2.new(0,200,0,50)
    billboard.AlwaysOnTop = true

    local text = Instance.new("TextLabel")
    text.Size = UDim2.new(1,0,1,0)
    text.BackgroundTransparency = 1
    text.TextStrokeTransparency = 0
    text.TextScaled = true
    text.Parent = billboard

    billboard.Parent = game.CoreGui

    -- เส้น
    local line = Drawing.new("Line")
    line.Thickness = 1

    esp.Highlight = highlight
    esp.Billboard = billboard
    esp.Text = text
    esp.Line = line

    ESPObjects[plr] = esp
end

local function RemoveESP(plr)
    if ESPObjects[plr] then
        local esp = ESPObjects[plr]

        if esp.Highlight then esp.Highlight:Destroy() end
        if esp.Billboard then esp.Billboard:Destroy() end
        if esp.Line then esp.Line:Remove() end

        ESPObjects[plr] = nil
    end
end

RunService.RenderStepped:Connect(function()
    if not ESPEnabled then return end

    local color = getRGB()

    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= player then

            if not ESPObjects[plr] then
                CreateESP(plr)
            end

            local esp = ESPObjects[plr]
            local char = plr.Character
            local hrp2 = char and char:FindFirstChild("HumanoidRootPart")

            if char and hrp2 then
                local dist = (hrp.Position - hrp2.Position).Magnitude

                -- BOX
                if ESP_Box then
                    esp.Highlight.Adornee = char
                    esp.Highlight.OutlineColor = color
                    esp.Highlight.Enabled = true
                else
                    esp.Highlight.Enabled = false
                end

                -- NAME + DIST
                if ESP_Name or ESP_Distance then
                    esp.Billboard.Adornee = hrp2
                    esp.Text.TextColor3 = color

                    local txt = ""
                    if ESP_Name then
                        txt = plr.Name
                    end
                    if ESP_Distance then
                        txt = txt .. " ["..math.floor(dist).."]"
                    end

                    esp.Text.Text = txt
                    esp.Billboard.Enabled = true
                else
                    esp.Billboard.Enabled = false
                end

                -- LINE
                if ESP_Line then
                    local pos, vis = workspace.CurrentCamera:WorldToViewportPoint(hrp2.Position)

                    if vis then
                        esp.Line.From = Vector2.new(workspace.CurrentCamera.ViewportSize.X/2, workspace.CurrentCamera.ViewportSize.Y)
                        esp.Line.To = Vector2.new(pos.X,pos.Y)
                        esp.Line.Color = color
                        esp.Line.Visible = true
                    else
                        esp.Line.Visible = false
                    end
                else
                    esp.Line.Visible = false
                end
            end
        end
    end
end)

Players.PlayerRemoving:Connect(RemoveESP)

