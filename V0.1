-- CHARACTER
-- =========================
local function getHRP()
    local char = player.Character or player.CharacterAdded:Wait()
    return char:WaitForChild("HumanoidRootPart")
end

local hrp = getHRP()

player.CharacterAdded:Connect(function()
    hrp = getHRP()
end)

-- =========================
-- TP
-- =========================
local function TP(cf)
    if hrp then
        hrp.CFrame = cf
    end
end

-- =========================
-- SETTINGS
-- =========================
local AutoBall = false
local Busy = false

local SellPos = CFrame.new(-75, 20, -102)

-- 🔥 เลือกเป้า
local SelectedValues = {
    ["50"] = false,
    ["100"] = false,
    ["500"] = false,
    ["1000"] = false,
    ["1"] = false,
    ["5"] = false
}

-- =========================
-- หาเป้า
-- =========================
local function GetTarget()
    local closestPrompt, closestPart
    local dist = math.huge

    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("ProximityPrompt") and v.ActionText then
            
            for val, enabled in pairs(SelectedValues) do
                if enabled and string.find(v.ActionText, val) then
                    
                    local part = v.Parent
                    if part and not part:IsA("BasePart") then
                        part = part:FindFirstChildWhichIsA("BasePart")
                    end

                    if part then
                        local d = (hrp.Position - part.Position).Magnitude
                        if d < dist then
                            dist = d
                            closestPrompt = v
                            closestPart = part
                        end
                    end
                end
            end

        end
    end

    return closestPart, closestPrompt
end

-- =========================
-- LOOP
-- =========================
task.spawn(function()
    while task.wait(0.2) do
        if AutoBall and not Busy and hrp then

            local part, prompt = GetTarget()

            if part and prompt then
                Busy = true

                TP(part.CFrame + Vector3.new(0,3,0))
                task.wait(0.2)

                local start = tick()
                while part and part.Parent do
                    fireproximityprompt(prompt)
                    task.wait(0.15)

                    if tick() - start > 5 then
                        break
                    end
                end

                task.wait(0.2)

                TP(SellPos)
                task.wait(0.3)

                for _, v in pairs(workspace:GetDescendants()) do
                    if v:IsA("ProximityPrompt") and v.ActionText and v.ActionText:lower():find("drop") then
                        
                        local p = v.Parent
                        if p and not p:IsA("BasePart") then
                            p = p:FindFirstChildWhichIsA("BasePart")
                        end

                        if p and (p.Position - SellPos.Position).Magnitude < 15 then
                            
                            local t = tick()
                            while tick() - t < 2 do
                                fireproximityprompt(v)
                                task.wait(0.2)
                            end

                        end
                    end
                end

                task.wait(0.5)
                Busy = false
            end
        end
    end
end)

